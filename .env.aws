# AWS Configuration for OpenBB
# Copy this to .env and fill in the actual values after AWS resources are created

# AWS RDS PostgreSQL
AWS_RDS_HOST=your-rds-endpoint.region.rds.amazonaws.com
AWS_RDS_PORT=5432
AWS_RDS_DATABASE=openbb_db
AWS_RDS_USERNAME=openbb_admin
AWS_RDS_PASSWORD=your-secure-password

# AWS ElastiCache Redis
AWS_REDIS_HOST=your-elasticache-endpoint.region.cache.amazonaws.com
AWS_REDIS_PORT=6379

# Constructed URLs
DATABASE_URL=postgresql://openbb_admin:your-secure-password@your-rds-endpoint.region.rds.amazonaws.com:5432/openbb_db
REDIS_URL=redis://your-elasticache-endpoint.region.cache.amazonaws.com:6379

# Keep existing API keys
OPENBB_PAT=${OPENBB_PAT}
ALPHA_VANTAGE_API_KEY=${ALPHA_VANTAGE_API_KEY}
POLYGON_API_KEY=${POLYGON_API_KEY}
FMP_API_KEY=${FMP_API_KEY}
BENZINGA_API_KEY=${BENZINGA_API_KEY}
API_NINJAS_KEY=${API_NINJAS_KEY}
OPENAI_API_KEY=${OPENAI_API_KEY}

# MindsDB (still local)
MINDSDB_URL=http://localhost:47334
MINDSDB_USERNAME=mindsdb
MINDSDB_PASSWORD=mindsdb

# OnlyOffice (still local)
ONLYOFFICE_SERVER_URL=http://localhost:9080