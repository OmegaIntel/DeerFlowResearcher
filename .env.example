# OpenBB Environment Configuration Example
# Copy this file to .env and fill in your actual values

# AWS Configuration
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_DEFAULT_REGION=us-east-1

# AWS RDS Configuration
AWS_RDS_HOST=your_rds_endpoint_here
AWS_RDS_PORT=3306
AWS_RDS_USER=admin
AWS_RDS_PASSWORD=your_rds_password_here
AWS_RDS_DATABASE=omega_intelligence

# AWS ElastiCache Configuration
AWS_ELASTICACHE_HOST=your_elasticache_endpoint_here
AWS_ELASTICACHE_PORT=6379

# Redis Configuration (for local or ElastiCache)
REDIS_HOST=your_redis_host_here
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# MindsDB Configuration
MINDSDB_URL=http://mindsdb:47334
MINDSDB_USERNAME=mindsdb
MINDSDB_PASSWORD=

# API Keys
BENZINGA_API_KEY=your_benzinga_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
API_NINJAS_KEY=your_api_ninjas_key_here
OPENBB_PAT=your_openbb_pat_here

# Application Configuration
BACKEND_URL=http://backend:8000
FRONTEND_URL=http://frontend:3000

# Docker Network
DOCKER_NETWORK=openbb_default
