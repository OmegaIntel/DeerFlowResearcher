# AWS Configuration for OpenBB
# Replace these values with your actual AWS credentials and endpoints

# AWS RDS PostgreSQL Configuration
AWS_RDS_HOST=your-rds-endpoint.region.rds.amazonaws.com
AWS_RDS_PORT=5432
AWS_RDS_DATABASE=openbb_db
AWS_RDS_USERNAME=openbb_admin
AWS_RDS_PASSWORD=your-secure-password

# AWS ElastiCache Redis Configuration
AWS_REDIS_HOST=your-elasticache-endpoint.region.cache.amazonaws.com
AWS_REDIS_PORT=6379

# Database URLs for application
DATABASE_URL=postgresql://openbb_admin:your-secure-password@your-rds-endpoint.region.rds.amazonaws.com:5432/openbb_db
REDIS_URL=redis://your-elasticache-endpoint.region.cache.amazonaws.com:6379

# AWS Region
AWS_REGION=us-east-1

# Security Group IDs (to be filled after creation)
RDS_SECURITY_GROUP_ID=
ELASTICACHE_SECURITY_GROUP_ID=